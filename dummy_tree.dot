digraph ParseTree {
    node [shape=box, fontname="Courier"];
    node1 [label="<program>"];
    node2 [label="<program-header>"];
    node1 -> node2;
    node3 [label="programsy"];
    node2 -> node3;
    node4 [label="ident(Hello)"];
    node2 -> node4;
    node5 [label="semicolon"];
    node2 -> node5;
    node6 [label="<declaration-part>"];
    node1 -> node6;
    node7 [label="<compound-statement>"];
    node1 -> node7;
    node8 [label="period"];
    node1 -> node8;
}
